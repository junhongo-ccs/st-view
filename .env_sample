# ==============================
# Vessel Tracking Dashboard
# Environment Variables Template
# ==============================

# 実行モード: DUMMY / API
DATA_MODE=DUMMY

# デフォルト海域: TOKYO_BAY / OSAKA_BAY / ISE_BAY / SETOUCHI / NORTH_KYUSHU
DEFAULT_AREA=TOKYO_BAY

# 自動更新間隔(秒): 30 / 60 / 120
REFRESH_SECONDS=30

# 保持する最新レコード件数
MAX_RECORDS=500

# 使用プロバイダ: AISSTREAM のみ（PoC）
AIS_PROVIDER=AISSTREAM

# --- API Keys ---
# AISstream (WebSocket) API Key
AISSTREAM_API_KEY=YOUR_AISSTREAM_API_KEY

# Datalastic API Key（有償のためPoC対象外。必要時のみ有効化）
# DATALASTIC_API_KEY=

# --- Optional ---
# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# タイムゾーン
TZ=Asia/Tokyo
